# BlackboxNLP 2026 — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Large files — cached activations and model weights
results/activations/*.pt
results/directions/*.pt

# Don't ignore figures — they should be version controlled
# results/figures/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Model downloads (don't commit these)
models/
*.bin
*.safetensors
*.gguf

# Downloaded / regenerable benchmark data (raw + intermediate converter output).
# The canonical per-domain pairs under data/prompt_pairs/ ARE committed.
data/truthfulqa/
data/advbench/

# Logs
*.log
wandb/

# Regenerable prompt-based refusal contrast (built by build_refusal_promptbased.py)
data/prompt_pairs_promptbased/
paper_overleaf.zip
